**/*.jks

# ---- iOS ----
ios/Flutter/.last_build_id
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Flutter.podspec
ios/.symlinks/
ios/Pods/
ios/DerivedData/
**/xcuserdata/
**/build/
# Workspace y Pods los recrea CocoaPods; el proyecto Runner sí se versiona
# (Deja Podfile y Podfile.lock en el repo)
# Si tu equipo prefiere commitear Pods, quita ios/Pods/ de aquí.

