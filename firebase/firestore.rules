rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tales/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /tales_common_data/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    // Drafts: only the admin. Email/Password sign-up is open by default,
    // so request.auth != null is insufficient. Lock to the admin uid.
    match /tale_drafts/{document} {
      allow read, write: if request.auth.uid == "N5sv9GubvwOvapwv72nwrhWzBtK2";
    }

    // Categories: read public (reader app may use later), write admin-only.
    match /categories/{document} {
      allow read: if true;
      allow write: if request.auth.uid == "N5sv9GubvwOvapwv72nwrhWzBtK2";
    }
  }
}
