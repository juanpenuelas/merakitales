rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tales/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /tales_common_data/{document} {
      allow create: if false;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }
  }
}
